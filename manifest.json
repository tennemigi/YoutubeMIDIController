{
  "manifest_version": 3,
  "name": "YouTube MIDI Controller",
  "short_name": "YT MIDI",
  "description": "Unofficial Chrome extension for controlling YouTube with a DDJ-FLX4 via MIDI.",
  "version": "0.2.0",
  "permissions": ["storage", "activeTab", "scripting", "midi", "tabs"],
  "host_permissions": ["https://www.youtube.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.youtube.com/*"],
      "js": ["content.js"]
    }
  ],
  "options_page": "options.html"
}
